# ──────────────────────────────────────────
# Prisma — Valcann Cloud Intelligence
# Copie para .env e preencha com as credenciais
# do app criado em developer.atlassian.com
# ──────────────────────────────────────────

# App OAuth 2.0 criado no Atlassian Developer Console

VITE_JIRA_CLIENT_ID=seu_client_id_aqui
VITE_JIRA_CLIENT_SECRET=seu_client_secret
# ID da instância Jira da Valcann
# Encontre em: https://developer.atlassian.com/console/myapps/ → seu app → Authorization

VITE_JIRA_CLOUD_ID=id_da_instancia_aqui
#Para o Cloud ID, acesse https://valcann.atlassian.net/_edge/tenant_info logado — o campo cloudId é o que você precisa

# URL base do Jira da Valcann
VITE_JIRA_BASE_URL=https://valcann.atlassian.net
